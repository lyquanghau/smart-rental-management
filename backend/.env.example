PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/smart_rental_dev
JWT_SECRET=change_me
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
# Dung CLIENT_URLS khi can cho phep nhieu frontend origin, cach nhau bang dau phay.
# Vi du: CLIENT_URLS=http://localhost:5173,https://smart-rental.vercel.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
